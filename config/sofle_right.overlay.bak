
/ {
    output_haptic_feedback: output_haptic_feedback {
        compatible = "zmk,output-haptic";
        device = <&drv2605_0>;
        driver = "drv2605";
        status = "okay";
    };

    output_relay_config_201: output_relay_config_201 {
        compatible = "zmk,split-peripheral-output-relay";
        device = <&output_haptic_feedback>;
        relay-channel = <201>;
    };
};

&drv2605_right {
    output-device = <&output_haptic_feedback>;
};
